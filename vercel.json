{
  "rewrites": [
    { "source": "/api/claude", "destination": "/api/claude.js" },
    { "source": "/api/login", "destination": "/api/login.js" },
    { "source": "/api/github", "destination": "/api/github.js" },
    { "source": "/api/onedrive", "destination": "/api/onedrive.js" },
    { "source": "/api/onedrive-auth", "destination": "/api/onedrive-auth.js" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}
